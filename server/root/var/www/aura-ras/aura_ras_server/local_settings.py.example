# aura_ras_server/local_settings.py.example
# Copy this file to local_settings.py and update with your production secrets.

# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY = 'your-django-secret-key'

# AuraRAS specific secrets and config
AURA_API_SECRET = 'your-api-secret-key'

# Add your server's IP and/or Domain Name here
ALLOWED_HOSTS = ['your-server.company.com', '123.123.123.123', 'localhost', '127.0.0.1']

# Database configuration
DATABASES = {
    'default': {
        'ENGINE': 'django.db.backends.mysql',
        'NAME': 'auraras_db',
        'USER': 'auraras_user',
        'PASSWORD': 'your-db-password',
        'HOST': 'localhost',
        'PORT': '3306',
    }
}

# Entra ID / OIDC credentials
OIDC_RP_CLIENT_ID = 'your-entra-id-client-id'
OIDC_RP_CLIENT_SECRET = 'your-entra-id-client-secret'
OIDC_RP_SIGN_ALGO = 'RS256'
OIDC_OP_AUTHORIZATION_ENDPOINT = 'https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/authorize'
OIDC_OP_TOKEN_ENDPOINT = 'https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/token'
OIDC_OP_USER_ENDPOINT = 'https://graph.microsoft.com/oidc/userinfo'
OIDC_OP_JWKS_ENDPOINT = 'https://login.microsoftonline.com/your-tenant-id/discovery/v2.0/keys'
LOGIN_REDIRECT_URL = '/'
LOGOUT_REDIRECT_URL = '/'

# Telemetry log path
APP_LOG_DIR = '/var/log/aura-ras'